# Backend Environment Variables
# Replace USER / CHANGE_ME / DB_HOST / DB_PORT / DB_NAME with the deployment's
# values. Password must be URL-encoded (e.g. '@' -> '%40'). Do NOT commit a
# real password back into this file.
DATABASE_URL=mysql+aiomysql://USER:CHANGE_ME@DB_HOST:3306/DB_NAME

# Agent settings
AGENT_REQUEST_TIMEOUT=30
HEALTH_CHECK_INTERVAL=5
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_MAX_RETRIES=3

# Network configuration
IPV6_NETWORK=2001:db8:1::/64
IPV4_NETWORK=10.0.1.0/24
# 开发期数据面 IPv4 与管理面同源；验收时再配 business_ipv6 并设为 true
PREFER_BUSINESS_IPV6=false

# Scheduler
APSCHEDULER_TIMEZONE=Asia/Shanghai

# Auth & service integration
SERVICE_API_TOKEN=change-me-service-token
AUTH_SECRET=change-me-auth-secret
ACCESS_TOKEN_EXPIRE_HOURS=24

# MinIO (result object URIs; local dev container on :9000)
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=task-results
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin1234

# Worker containers report metrics back to the Manager (this process).
# By default the URL is derived at startup from the `nodes` table:
#   SELECT management_ip FROM nodes WHERE hostname = $BACKEND_HOSTNAME
# combined with BACKEND_PORT, so deployments only need to register the
# backend host once and every worker callback URL stays consistent.
#
# BACKEND_HOSTNAME defaults to "admin"; set it if the row uses a different name.
# BACKEND_PORT defaults to 8000; set it if uvicorn binds elsewhere.
# If BACKEND_HOSTNAME is missing from the nodes table the backend will fail
# to start with a clear error.
#
# MANAGER_PUBLIC_URL, when set, OVERRIDES the lookup. Use this only when the
# backend is reachable via a URL that does not match its registered
# management_ip (e.g. behind NAT / reverse proxy).
# BACKEND_HOSTNAME=admin
# BACKEND_PORT=8000
# MANAGER_PUBLIC_URL=http://10.0.0.1:8000
PLATFORM_SCRATCH_ROOT=/tmp/manage_deploy

# Intent parser / LLM evaluation
# rule: deterministic local parser; llm: Qwen via DashScope with rule fallback.
INTENT_PARSER_ENGINE=rule
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
# Comma-separated candidates exposed on the admin intent evaluation page.
# Keep only models that complete the smoke test:
#   python scripts/smoke_dashscope_batch_models.py --models qwen3.7-plus qwen-long qwen3-max
DASHSCOPE_EVAL_MODELS=qwen3.7-plus,qwen-long
DASHSCOPE_TIMEOUT=30
DASHSCOPE_TEMPERATURE=0.1
